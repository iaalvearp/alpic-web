---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="page-container">
		<section class="intro" aria-labelledby="page-title">
			<div class="intro__topline">
				<p class="intro__eyebrow">Galería pública · AlPic</p>
				<div id="theme-menu" class="theme-menu">
					<div id="theme-options" class="theme-options" aria-label="Opciones de tema">
						<button class="theme-option" type="button" data-theme-option="system" aria-label="Tema del sistema" title="Tema del sistema" aria-pressed="true" tabindex="-1">
							<svg aria-hidden="true" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="13" rx="2"></rect><path d="M8 21h8M12 17v4"></path></svg>
						</button>
						<button class="theme-option" type="button" data-theme-option="light" aria-label="Tema claro" title="Tema claro" aria-pressed="false" tabindex="-1">
							<svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42"></path></svg>
						</button>
						<button class="theme-option" type="button" data-theme-option="dark" aria-label="Tema oscuro" title="Tema oscuro" aria-pressed="false" tabindex="-1">
							<svg aria-hidden="true" viewBox="0 0 24 24"><path d="M20.5 14.1A8.5 8.5 0 0 1 9.9 3.5 8.5 8.5 0 1 0 20.5 14.1Z"></path></svg>
						</button>
					</div>
					<button id="theme-toggle" class="theme-button" type="button" aria-label="Abrir opciones de tema. Tema del sistema seleccionado" title="Tema del sistema" aria-expanded="false" aria-controls="theme-options">
						<svg data-theme-icon="system" aria-hidden="true" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="13" rx="2"></rect><path d="M8 21h8M12 17v4"></path></svg>
						<svg data-theme-icon="light" aria-hidden="true" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.65 17.65l1.42 1.42M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.65 6.35l1.42-1.42"></path></svg>
						<svg data-theme-icon="dark" aria-hidden="true" viewBox="0 0 24 24"><path d="M20.5 14.1A8.5 8.5 0 0 1 9.9 3.5 8.5 8.5 0 1 0 20.5 14.1Z"></path></svg>
					</button>
				</div>
			</div>
			<h1 id="page-title">Fotos de Al<span>Pic</span></h1>
			<p class="intro__subtitle">Un catálogo visual que centraliza imágenes y entrega solo los datos necesarios para reutilizarlas en otros proyectos.</p>
		</section>

		<section class="gallery-section" aria-labelledby="gallery-heading">
			<div class="gallery-heading">
				<h2 id="gallery-heading">Colección</h2>
				<p id="gallery-status" role="status" aria-live="polite">Cargando imágenes…</p>
			</div>
			<div id="gallery" class="gallery" data-state="loading" aria-busy="true">
				<div class="skeleton skeleton--feature"></div>
				<div class="skeleton skeleton--portrait"></div>
				<div class="skeleton"></div>
				<div class="skeleton skeleton--wide"></div>
			</div>
		</section>
	</main>
	<footer><div class="page-container"><p>Contenido público sincronizado desde AlPic.</p></div></footer>
</Layout>
